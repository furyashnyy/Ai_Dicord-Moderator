# ─────────────────────────────────────────────────────────────
# Discord credentials (required)
# ─────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your-bot-token-here
# Application (client) ID — used to register slash commands
DISCORD_CLIENT_ID=your-application-id-here

# Comma-separated list of guild (server) IDs the bot is allowed to moderate.
# The bot will ONLY moderate messages in these guilds.
# Leave empty to allow every guild the bot is in (a warning is logged).
ALLOWED_GUILD_IDS=

# Optional: register slash commands to a single guild for instant updates
# during development. Leave empty to register globally (can take ~1h to appear).
DEV_GUILD_ID=

# ─────────────────────────────────────────────────────────────
# Database (Prisma + SQLite)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./data/moderation.db"

# ─────────────────────────────────────────────────────────────
# AI models (@xenova/transformers, ONNX / CPU, int8 quantized)
# ─────────────────────────────────────────────────────────────
# Toggle the ML toxicity classifier. When false, only the RU+EN lexicon
# is used for the general-toxicity signal (fully offline, ~0 extra RAM).
ENABLE_TOXICITY_MODEL=true
# Text-classification model for contextual toxicity.
# Default is English-leaning; the RU+EN lexicon covers Russian profanity,
# and the multilingual embedding model covers semantic rule matching.
TOXICITY_MODEL=Xenova/toxic-bert

# Toggle semantic (embedding) matching of messages against rule text.
# Disable to stay under ~1GB RAM if the toxicity model is also loaded.
ENABLE_EMBEDDINGS=true
# Multilingual sentence-embedding model (RU+EN out of the box, ~470MB int8).
EMBEDDING_MODEL=Xenova/paraphrase-multilingual-MiniLM-L12-v2

# Use int8-quantized model weights (recommended, much smaller RAM footprint).
USE_QUANTIZED_MODELS=true

# Where transformer weights are cached on disk.
TRANSFORMERS_CACHE=./models

# ─────────────────────────────────────────────────────────────
# Moderation defaults (can be overridden per-guild via slash commands)
# ─────────────────────────────────────────────────────────────
# Cosine-similarity threshold for matching a message to a rule (0..1).
DEFAULT_SIMILARITY_THRESHOLD=0.55
# Toxicity score above which the guild "default action" may trigger (0..1).
DEFAULT_TOXICITY_THRESHOLD=0.8

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
# one of: debug | info | warn | error
LOG_LEVEL=info
